# Supabase project URL
# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable (public) key — safe for browser code
# Supabase Dashboard → Project Settings → API → publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key — SERVER ONLY, never expose to the browser
# Supabase Dashboard → Project Settings → API → secret key
SUPABASE_SECRET_KEY=
